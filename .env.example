# ============================================================
# Stratos1 Trading Bot - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# --- Telegram User Session (Telethon - for reading private groups) ---
TG_API_ID=your_api_id_here
TG_API_HASH=your_api_hash_here
TG_PHONE=+46000000000
# Generate this by running SETUP_TELEGRAM.bat (one time only)
TG_SESSION_STRING=

# --- Telegram Bot (for sending notifications) ---
TG_BOT_TOKEN=your_bot_token_here

# --- Telegram Target Channel (where bot posts reports) ---
TG_NOTIFY_CHANNEL_ID=-100xxxxxxxxxx

# --- Bybit API (Demo/Testnet first, then live) ---
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BYBIT_DEMO=true
